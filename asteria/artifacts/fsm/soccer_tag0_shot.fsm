from aim_fsm import *
from soccer_search_nodes import ShootHeldBallAtTag0


class SoccerTag0Shot(StateMachineProgram):
    $setup{
    start: Say("Starting soccer tag zero shot") =C=> shoot_ball

    shoot_ball: ShootHeldBallAtTag0()
    shoot_ball =C=> done
    shoot_ball =F=> failed

    done: Say("Soccer shot complete")
    failed: Print("soccer_tag0_shot failed")
    }
